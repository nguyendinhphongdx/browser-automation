generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  scripts        Script[]
  reviews        Review[]
  syncedProfiles SyncedProfile[]
  profileBackups ProfileBackup[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Role {
  USER
  PRO
  CREATOR
  ADMIN
}

// ─── Profile Sync ───────────────────────────────────────────

model SyncedProfile {
  id          String   @id @default(cuid())
  userId      String
  localId     String   // id của profile trên desktop
  name        String
  browserType String
  tags        String[]
  color       String   @default("#3B82F6")
  data        String   // JSON đầy đủ của profile (fingerprint, proxy, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, localId])
  @@map("synced_profiles")
}

// ─── Profile Backup ─────────────────────────────────────────

model ProfileBackup {
  id         String   @id @default(cuid())
  userId     String
  profileId  String   // localId từ desktop
  name       String
  size       Int      // bytes
  storageKey String   // path/key trong storage provider
  provider   String   // "s3" hoặc "gcs"
  checksum   String   // SHA-256 hash của file zip
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profile_backups")
}

// ─── Marketplace ─────────────────────────────────────────────

model Script {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String
  version     String       @default("1.0.0")
  category    String
  tags        String[]
  price       Int          @default(0) // in cents, 0 = free
  status      ScriptStatus @default(PENDING)
  downloads   Int          @default(0)
  authorId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  author  User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@map("scripts")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int // 1-5
  comment   String?
  scriptId  String
  userId    String
  createdAt DateTime @default(now())

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scriptId, userId])
  @@map("reviews")
}

enum ScriptStatus {
  PENDING
  APPROVED
  REJECTED
}

DATABASE_URL="postgresql://user:password@localhost:5432/browser_automation?schema=public"

# Auth.js
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# JWT cho desktop app API
JWT_SECRET="generate-a-random-secret-here"

# Stripe (marketplace payments)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_URL="http://localhost:3000"

# Backup storage provider: "s3" hoặc "gcs"
STORAGE_PROVIDER="gcs"

# S3 config
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET=""

# GCS config (thay thế cho S3)
GCS_BUCKET=browserpack-backups
GCS_CREDENTIALS=""  # Raw JSON service account credentials
GCS_KEY_FILE=""     # Hoặc đường dẫn file key (ưu tiên GCS_CREDENTIALS nếu cả 2 có)
